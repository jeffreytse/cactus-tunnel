{
  "name": "cactus-tunnel",
  "version": "0.4.0",
  "description": "TCP tunnel over WebSocket and Browser",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "cactus-tunnel": "bin/cactus-tunnel.js"
  },
  "files": [
    "bin",
    "src",
    "views",
    "public/img",
    "public/css/*.css",
    "public/js/*.js",
    "public/*.html",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "tcp",
    "tunnel",
    "websocket",
    "http",
    "browser",
    "proxy",
    "cli",
    "socks5"
  ],
  "scripts": {
    "start": "npm run serve",
    "start:cli": "npm run cli",
    "build": "rimraf dist && tsc && npm run bundle && npm run copy",
    "bundle": "vite build",
    "copy": "cpy LICENSE README.md ./dist",
    "serve": "node dist/src/index.js",
    "cli": "node dist/bin/cactus-tunnel.js",
    "lint": "eslint . --ext .ts",
    "test": "npm run build && jest",
    "pac": "NODE_ENV=production npm test && cd dist && npm pack",
    "pub": "NODE_ENV=production npm test && cd dist && npm publish",
    "prepack": "test -f package-lock.json && echo please use npm run pac && exit 1 || true",
    "prepublishOnly": "test -f package-lock.json && echo please use npm run pub && exit 1 || true",
    "globalInstall": "npm i -g ./dist/cactus-tunnel-${npm_package_version}.tgz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffreytse/cactus-tunnel.git"
  },
  "author": "Jeffrey Tse <hello@jeffreytse.net>",
  "homepage": "https://github.com/jeffreytse/cactus-tunnel#readme",
  "bugs": {
    "url": "https://github.com/jeffreytse/cactus-tunnel/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/express": "^4.17.25",
    "@types/express-ws": "^3.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/pump": "^1.1.3",
    "@types/winston": "^2.4.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "axios": "^1.16.1",
    "cpy-cli": "^4.2.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "puppeteer": "^19.11.1",
    "rimraf": "^3.0.2",
    "typescript": "^4.9.5",
    "vite": "^5.0.0",
    "vite-plugin-node-polyfills": "^0.22.0"
  },
  "dependencies": {
    "commander": "^9.5.0",
    "express": "^4.22.2",
    "express-ws": "^5.0.2",
    "open": "^8.4.2",
    "pump": "^3.0.4",
    "websocket-stream": "^5.5.2",
    "winston": "^3.19.0",
    "ws": "^8.20.1"
  }
}
